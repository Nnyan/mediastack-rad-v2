# ── Port ─────────────────────────────────────────────────────────────────────
PORT=8090

# ── Compose auto-apply ────────────────────────────────────────────────────────
# Directory on the HOST that contains your media stack docker-compose.yml.
# This gets mounted at /compose inside the mediastack-rad container.
# The app will read, patch, and write this file when you click "Apply & recreate".
COMPOSE_DIR=/opt/mediastack

# Full path to the compose file INSIDE the container (after the mount above).
# Only change this if your compose file has a non-standard name.
COMPOSE_FILE_PATH=/compose/docker-compose.yml

# ── Traefik integration ───────────────────────────────────────────────────────
TRAEFIK_ENABLE=false
TRAEFIK_HOST=mediastack-rad.yourdomain.com

# ── Docker network ────────────────────────────────────────────────────────────
# To attach to an existing Docker network (e.g. your mediastack network):
#   DOCKER_NETWORK=mediastack
#   NETWORK_EXTERNAL=true
DOCKER_NETWORK=mediastack-rad
NETWORK_EXTERNAL=false
