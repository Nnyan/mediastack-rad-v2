# ============================================================================
# MediaStack-RAD — environment variable reference
#
# Copy this file to .env and adjust the values for your setup.
# Variables marked REQUIRED must be set. All others have working defaults.
# ============================================================================

# [REQUIRED] Host path where RAD writes the managed stack's docker-compose.yml.
# This directory will contain the generated compose file and per-service
# config subdirectories. Mount this into the RAD container as /compose.
STACK_DIR=/home/stack/mediacenter

# Path to Traefik's config directory on the host.
# Traefik mounts /letsencrypt and /etc/traefik from here.
# Defaults to $STACK_DIR/config/traefik inside the container.
# RAD_TRAEFIK_DIR=/home/stack/mediacenter/config/traefik

# Docker socket path inside the RAD container.
# Only change this if you use a non-standard socket location.
# RAD_DOCKER_SOCKET=unix:///var/run/docker.sock

# Host and port the RAD API listens on inside the container.
# The docker-compose.yml maps port 8090 by default.
# RAD_BIND_HOST=0.0.0.0
# RAD_BIND_PORT=8090

# How often (seconds) the background health checker re-runs.
# RAD_HEALTH_INTERVAL=30

# How often (seconds) container CPU/memory stats are sampled for the
# live dashboard WebSocket feed.
# RAD_STATS_INTERVAL=2.0

# ── Stack credentials ────────────────────────────────────────────────────────
# These are written into the managed stack's .env file via Settings → Secrets.
# You can pre-populate them here so they're available on first deploy.

# Cloudflare DNS API token — required for DNS-01 HTTPS cert issuance via Traefik.
# Needs Zone:DNS:Edit + Zone:Zone:Read on your domain.
# CLOUDFLARED_TOKEN=

# Cloudflare Tunnel token — required only if using cloudflared in the stack.
# Get it from: Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Install connector.
# CF_DNS_API_TOKEN=
