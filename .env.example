# Host path where RAD will write your managed stack's docker-compose.yml.
# This directory will contain the generated compose file, a config/
# subdir for each service, and traefik/ with certificates.
STACK_DIR=/home/stack/mediacenter

# Cloudflare tunnel token, required only if you use cloudflared in your
# managed stack. Get it from Cloudflare Zero Trust → Networks → Tunnels
# → your tunnel → Install connector. Not needed if you port-forward.
# CLOUDFLARED_TOKEN=
